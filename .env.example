# Neon Postgres
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Neon Auth (from Neon Console or provision_neon_auth MCP)
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=generate-with-openssl-rand-base64-32
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin signup gate
ADMIN_INVITE_CODE=your-secret-invite-code

# Client session signing (min 32 chars)
SESSION_SECRET=generate-another-long-random-string

# Reveal project passwords in admin (min 32 chars)
ENCRYPTION_KEY=generate-yet-another-long-random-string
